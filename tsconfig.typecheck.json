{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "skipLibCheck": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noEmit": true
  },
  "include": [
    "extension/**/*.ts",
    "bin/**/*.ts",
    "scripts/**/*.mjs",
    "scripts/**/*.ts",
    "tests/**/*.ts"
  ]
}
