{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "outDir": "dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "paths": {
      "@tintinweb/pi-subagents": ["./node_modules/@tintinweb/pi-subagents/dist/index.d.ts"],
      "@tintinweb/pi-subagents/dist/index.js": ["./node_modules/@tintinweb/pi-subagents/dist/index.d.ts"]
    }
  },
  "include": [
    "extension/**/*.ts",
    "bin/**/*.ts",
    "scripts/**/*.mjs"
  ],
  "exclude": ["node_modules", "dist", "data"]
}
