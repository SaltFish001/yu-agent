{
  "name": "yu-agent",
  "version": "0.1.0",
  "description": "DeepSeek-native programming agent dispatcher for Pi — scheduler + sub-agents + team mode",
  "type": "module",
  "author": "",
  "license": "MIT",
  "repository": {
    "url": "https://github.com/SaltFish001/yu-agent.git"
  },
  "keywords": [
    "pi-package",
    "pi",
    "pi-extension",
    "coding-agent",
    "deepseek"
  ],
  "pi": {
    "extensions": [
      "./extension/identity.ts",
      "./extension/session-store.ts",
      "./extension/resumer.ts",
      "./extension/session-cmd.ts",
      "./extension/monitor.ts",
      "./extension/memory-plugin.ts",
      "./extension/index.ts"
    ]
  },
  "bin": {
    "yu": "./dist/bin/yu.js"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "biome lint .",
    "lint:fix": "biome lint --apply .",
    "format": "biome format .",
    "format:fix": "biome format --write .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@colbymchenry/codegraph": "latest",
    "@earendil-works/pi-coding-agent": ">=0.74.0",
    "@tintinweb/pi-subagents": "^0.8.0",
    "duckduckgo-websearch": "^2.0.3",
    "opencode-codebase-index": "latest",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@biomejs/js-api": "^4.0.0",
    "@types/node": "^22.19.19",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
