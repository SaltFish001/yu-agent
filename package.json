{
  "name": "@saltfish001/yu-agent",
  "engines": {
    "bun": ">=1.2"
  },
  "version": "0.2.0-beta",
  "description": "DeepSeek-native AI programming agent — AgentLoop + ToolRegistry + Web UI",
  "type": "module",
  "author": "",
  "license": "MIT",
  "repository": {
    "url": "https://github.com/SaltFish001/yu-agent.git"
  },
  "publishConfig": {
    "access": "restricted",
    "registry": "https://npm.pkg.github.com/"
  },
  "keywords": [
    "coding-agent",
    "deepseek",
    "ai",
    "cli"
  ],
  "bin": {
    "yu": "./dist/bin/yu.js"
  },
  "scripts": {
    "build": "bun build ./bin/yu.ts --outdir ./dist --target bun --external @biomejs/js-api --external @biomejs/biome --external '@tintinweb/*' --external '@earendil-works/*'",
    "build:web": "bun build ./webui/assets/client.ts --outdir ./webui/assets --target browser --minify",
    "postbuild": "bun -e \"import { cpSync, existsSync, mkdirSync } from 'fs'; import { resolve } from 'path'; import { homedir } from 'os'; const src = resolve(import.meta.dir, 'prompts'); const dst = resolve(homedir(), '.yu', 'prompts'); if (!existsSync(dst)) mkdirSync(dst, { recursive: true }); cpSync(src, dst, { recursive: true, force: true }); console.log('Prompts synced to ' + dst);\"",
    "typecheck": "tsc --noEmit --project tsconfig.typecheck.json",
    "lint": "biome lint ./bin/ ./extension/ ./tests/",
    "lint:fix": "biome check --write --unsafe ./bin/ ./extension/ ./tests/",
    "format": "biome format .",
    "format:fix": "biome format --write .",
    "test": "bun test",
    "test:watch": "bun test --watch"
  },
  "dependencies": {
    "@colbymchenry/codegraph": "^0.9.9",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "duckduckgo-websearch": "^2.0.3",
    "hono": "^4.12.26",
    "zod": "^4.4.3"
  },
  "optionalDependencies": {
    "@earendil-works/pi-coding-agent": "^0.79.1",
    "@tintinweb/pi-subagents": "^0.10.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@biomejs/js-api": "^4.0.0",
    "@types/bun": "^1.3.14",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
